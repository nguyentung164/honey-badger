  "scripts": {
    "start": "electron-vite preview",
    "predev": "run-s clean:dev copy:material-icons copy:sarasa-fonts",
    "dev": "cross-env NODE_ENV=development electron-vite dev --watch",
    "compile:app": "electron-vite build",
    "compile:packageJSON": "tsx ./src/lib/electron-app/release/modules/prebuild.ts",
    "prebuild": "run-s clean:dev compile:app compile:packageJSON install:deps",
    "build": "pnpm electron-builder --publish never",
    "postinstall": "run-s copy:material-icons copy:sarasa-fonts prebuild install:deps install:electron",
    "copy:material-icons": "node scripts/copy-material-icons.mjs",
    "copy:sarasa-fonts": "node scripts/copy-sarasa-fonts.mjs",
    "install:deps": "node scripts/install-app-deps-safe.mjs",
    "install:electron": "node node_modules/electron/install.js",
    "make:release": "tsx ./src/lib/electron-app/release/modules/release.ts",
    "release": "pnpm electron-builder --publish always",
    "clean:dev": "rimraf ./node_modules/.dev",
    "lint": "biome lint --no-errors-on-unmatched",
    "test": "vitest",
    "lint:fix": "biome lint --write --no-errors-on-unmatched",
    "i18n:find-unused": "tsx scripts/find-unused-translation-keys.ts",
    "i18n:remove-unused": "tsx scripts/remove-unused-translation-keys.ts",
    "seed:mock": "cross-env APP_DB_HOST=xxx APP_DB_PORT=1234 APP_DB_NAME=postgres APP_DB_USER=postgres APP_DB_PASSWORD=xxx SEED_RANDOM=1 tsx src/main/task/seed/seedMockDataRun.ts",
    "export:rank-badges": "node scripts/export-rank-badges-svg.mjs",
    "export:rank-badges:all": "node scripts/export-rank-badges-svg.mjs --all",
    "crop:rank-badges": "node scripts/crop-rank-badges-svg.mjs"
  },
