  "scripts": {
    "start": "electron-vite preview",
    "predev": "run-s clean:dev",
    "dev": "cross-env NODE_ENV=development electron-vite dev --watch",
    "compile:app": "electron-vite build",
    "compile:packageJSON": "tsx ./src/lib/electron-app/release/modules/prebuild.ts",
    "prebuild": "run-s clean:dev compile:app compile:packageJSON",
    "build": "pnpm electron-builder --publish always",
    "postinstall": "run-s prebuild install:deps",
    "install:deps": "electron-builder install-app-deps",
    "make:release": "tsx ./src/lib/electron-app/release/modules/release.ts",
    "release": "pnpm electron-builder --publish always",
    "clean:dev": "rimraf ./node_modules/.dev",
    "lint": "biome lint --no-errors-on-unmatched",
    "test": "vitest",
    "lint:fix": "biome lint --write --no-errors-on-unmatched",
    "i18n:find-unused": "tsx scripts/find-unused-translation-keys.ts",
    "i18n:remove-unused": "tsx scripts/remove-unused-translation-keys.ts",
    "seed:mock": "cross-env TASK_DB_HOST=localhost TASK_DB_NAME=honey_badger TASK_DB_USER=root TASK_DB_PASSWORD=123456 tsx src/main/task/seedMockDataRun.ts",
    "seed:mock:reproducible": "cross-env TASK_DB_HOST=localhost TASK_DB_NAME=honey_badger TASK_DB_USER=root TASK_DB_PASSWORD=123456 SEED_RANDOM=12345 tsx src/main/task/seedMockDataRun.ts"
  },
